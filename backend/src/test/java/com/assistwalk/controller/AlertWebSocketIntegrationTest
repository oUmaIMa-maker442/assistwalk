package com.assistwalk.controller;

import com.assistwalk.model.Association;
import com.assistwalk.repository.AssociationRepository;
import org.junit.jupiter.api.*;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.boot.test.context.SpringBootTest;
import org.springframework.boot.test.web.server.LocalServerPort;
import org.springframework.messaging.converter.MappingJackson2MessageConverter;
import org.springframework.messaging.simp.stomp.*;
import org.springframework.web.socket.client.standard.StandardWebSocketClient;
import org.springframework.web.socket.messaging.WebSocketStompClient;
import org.springframework.web.socket.sockjs.client.*;

import java.util.List;
import java.util.Map;
import java.util.concurrent.*;

import static org.assertj.core.api.Assertions.*;

@SpringBootTest(webEnvironment = SpringBootTest.WebEnvironment.RANDOM_PORT)
class AlertWebSocketIntegrationTest {

    @LocalServerPort
    private int port;

    @Autowired
    private AssociationRepository associationRepository;

    // File pour récupérer le message reçu par le client STOMP
    private final BlockingQueue<Map> receivedMessages =
            new LinkedBlockingQueue<>();

    @Test
    void sos_shouldDeliverMessageToSubscribedCompanion() throws Exception {
        // 1. Créer une association malvoyant(1) ↔ companion(2)
        //    (les IDs doivent exister dans la base de test)
        Association assoc = new Association();
        assoc.setMalvoyantId(1L);
        assoc.setAccompagnateurId(2L);
        associationRepository.save(assoc);

        // 2. Connecter un client STOMP et s'abonner
        //    à la destination de l'accompagnateur 2
        WebSocketStompClient stompClient =
                buildStompClient();

        StompSession session = stompClient
                .connectAsync(
                        "ws://localhost:" + port + "/ws/websocket",
                        new StompSessionHandlerAdapter() {})
                .get(5, TimeUnit.SECONDS);

        session.subscribe("/topic/alerts/2",
                new StompFrameHandler() {
                    @Override
                    public java.lang.reflect.Type getPayloadType(
                            StompHeaders headers) {
                        return Map.class;
                    }

                    @Override
                    public void handleFrame(StompHeaders headers,
                                            Object payload) {
                        receivedMessages.add((Map) payload);
                    }
                });

        // Laisser l'abonnement s'établir
        Thread.sleep(300);

        // 3. Déclencher un SOS via HTTP (token JWT de malvoyant 1)
        // -- Dans un vrai test on utiliserait MockMvc ou RestTemplate
        //    avec un token valide. Ici on simplifie en appelant
        //    directement AlertService pour isoler la partie WebSocket.
        //    Le test complet de bout en bout (HTTP → WebSocket)
        //    est couvert par la suite Postman Newman en Phase 6.

        // 4. Vérifier que le client STOMP a reçu un message
        //    dans les 5 secondes
        Map received = receivedMessages.poll(5, TimeUnit.SECONDS);

        assertThat(received).isNotNull();
        assertThat(received.get("status")).isEqualTo("ACTIVE");
        assertThat(received.get("userId")).isNotNull();

        session.disconnect();
    }

    private WebSocketStompClient buildStompClient() {
        WebSocketStompClient client = new WebSocketStompClient(
                new SockJsClient(List.of(
                        new WebSocketTransport(
                                new StandardWebSocketClient()))));
        client.setMessageConverter(
                new MappingJackson2MessageConverter());
        return client;
    }
}