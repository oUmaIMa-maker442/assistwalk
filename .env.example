# .env.example — copier en .env et remplir les valeurs

# PostgreSQL
POSTGRES_DB=assistwalk
POSTGRES_USER=assistwalk_user
POSTGRES_PASSWORD=CHANGEME

# Spring Boot
DB_URL=jdbc:postgresql://localhost:5432/assistwalk
DB_USERNAME=assistwalk_user
DB_PASSWORD=CHANGEME

# JWT (choisir une chaîne aléatoire longue, ex: openssl rand -base64 32)
JWT_SECRET=CHANGEME
JWT_EXPIRATION_MS=86400000